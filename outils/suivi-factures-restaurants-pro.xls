<Row ss:StyleID="header"><Cell ss:Index="1" ss:StyleID="header"><Data ss:Type="String">Restaurant</Data></Cell><Cell ss:Index="2" ss:StyleID="header"><Data ss:Type="String">Solde crédit actuel (€)</Data></Cell><Cell ss:Index="3" ss:StyleID="header"><Data ss:Type="String">Alerte solde</Data></Cell><Cell ss:Index="4" ss:StyleID="header"><Data ss:Type="String">Encours impayé (€)</Data></Cell><Cell ss:Index="5" ss:StyleID="header"><Data ss:Type="String">Alerte encours</Data></Cell></Row>
<Row><Cell ss:Index="1"><Data ss:Type="String">My French factory</Data></Cell><Cell ss:Index="2" ss:Formula="='My French factory'!E13"><Data ss:Type="String"></Data></Cell><Cell ss:Index="3" ss:Formula="=SI(B2&amp;lt;=0;&amp;quot;⚠ RECHARGER 500 €&amp;quot;;&amp;quot;OK&amp;quot;)"><Data ss:Type="String"></Data></Cell><Cell ss:Index="4" ss:Formula="=SOMME('My French factory'!$C$2:$C$120)-SOMME.SI('My French factory'!$C$2:$C$120;'My French factory'!$G$2:$G$120;&amp;quot;Oui&amp;quot;)"><Data ss:Type="String"></Data></Cell><Cell ss:Index="5" ss:Formula="=SI(D2&amp;gt;500;&amp;quot;⚠ RELANCER&amp;quot;;&amp;quot;OK&amp;quot;)"><Data ss:Type="String"></Data></Cell></Row>
<Row><Cell ss:Index="1"><Data ss:Type="String">My french Cantine</Data></Cell><Cell ss:Index="2" ss:Formula="='My french Cantine'!E13"><Data ss:Type="String"></Data></Cell><Cell ss:Index="3" ss:Formula="=SI(B3&amp;lt;=0;&amp;quot;⚠ RECHARGER 500 €&amp;quot;;&amp;quot;OK&amp;quot;)"><Data ss:Type="String"></Data></Cell><Cell ss:Index="4" ss:Formula="=SOMME('My french Cantine'!$C$2:$C$120)-SOMME.SI('My french Cantine'!$C$2:$C$120;'My french Cantine'!$G$2:$G$120;&amp;quot;Oui&amp;quot;)"><Data ss:Type="String"></Data></Cell><Cell ss:Index="5" ss:Formula="=SI(D3&amp;gt;500;&amp;quot;⚠ RELANCER&amp;quot;;&amp;quot;OK&amp;quot;)"><Data ss:Type="String"></Data></Cell></Row>

